# ── Auth (Clerk) ─────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Database (Supabase / Neon / any Postgres) ────────────────────
# Get from: Supabase → Project Settings → Database → Connection string
# Pooled (pgBouncer) — port 6543, use at runtime
DATABASE_URL=
# Direct — port 5432, use for prisma db push / migrate
DIRECT_URL=

# ── Payments (Stripe) ────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create these in Stripe dashboard
STRIPE_PRICE_MONTHLY_STARTER=price_xxxxx   # $29/mo — 2,000 tokens
STRIPE_PRICE_MONTHLY_GROWTH=price_xxxxx    # $79/mo — 8,000 tokens
STRIPE_PRICE_PACK_SMALL=price_xxxxx        # $10 — 500 tokens
STRIPE_PRICE_PACK_MEDIUM=price_xxxxx       # $25 — 1,500 tokens
STRIPE_PRICE_PACK_LARGE=price_xxxxx        # $50 — 3,500 tokens
STRIPE_PRICE_PACK_XL=price_xxxxx           # $100 — 8,000 tokens

# ── AI (Claude / OpenAI) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# ── API Key Management (Unkey) ───────────────────────────────────
# Get from: https://app.unkey.com
UNKEY_ROOT_KEY=xxxxx
UNKEY_API_ID=xxxxx

# ── Domain & DNS (Cloudflare) ────────────────────────────────────
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=xxxxx
CLOUDFLARE_ZONE_ID=xxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxx
PLATFORM_DOMAIN=yourdomain.com   # Your platform's base domain for subdomains

# ── Email Hosting (Zoho Mail) ────────────────────────────────────
# Get from: https://mail.zoho.com/cpanel
ZOHO_CLIENT_ID=xxxxx
ZOHO_CLIENT_SECRET=xxxxx
ZOHO_REFRESH_TOKEN=xxxxx

# ── Email (Resend — for transactional emails) ────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@yourdomain.com

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-random-secret-32-chars-min
